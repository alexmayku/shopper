<div class="space-y-6 py-8 text-center">
  <div class="mx-auto w-16 h-16 rounded-full bg-amber-500 text-white flex items-center justify-center text-3xl">⏸</div>
  <h1 class="text-2xl font-semibold tracking-tight">Tesco needs to verify it's you</h1>
  <p class="text-sm text-neutral-500">
    Open the Tesco app or website, confirm it's you, then come back and tap Resume.
  </p>
  <%= button_to "Resume", resume_basket_build_path(basket_build), method: :post,
        class: button_classes(:primary, extra: "w-full") %>
  <%= link_to "Back to list", list_path, class: button_classes(:tertiary) %>
</div>
