<div id="share-modal" class="hidden target:flex fixed inset-0 z-40 items-center justify-center bg-black/40">
  <% share_url = shared_list_url(list.share_token, host: request.host_with_port) %>
  <div class="<%= card_classes(extra: "w-full max-w-sm mx-4 space-y-4") %>" data-controller="copy">
    <div class="flex items-baseline justify-between">
      <h2 class="text-lg font-semibold">Share list</h2>
      <a href="#" class="text-sm text-neutral-500 hover:text-neutral-900">Close</a>
    </div>
    <p class="text-sm text-neutral-600">Anyone with this link can add to your list.</p>
    <input type="text" readonly value="<%= share_url %>" data-copy-target="source" class="<%= input_classes %>">
    <div class="flex gap-2">
      <button type="button" data-action="copy#copy" class="<%= button_classes(:primary, extra: "flex-1") %>">
        <span data-copy-target="label">Copy link</span>
      </button>
      <%= button_to "Regenerate", rotate_share_token_path, method: :post,
            class: button_classes(:secondary),
            form: { data: { turbo_confirm: "Old link will stop working. Continue?" } } %>
    </div>
  </div>
</div>
