<div class="pt-4">
  <h1 class="text-3xl font-semibold tracking-tight mb-8">Create your account</h1>

  <% if @user.errors.any? %>
    <div class="mb-5 rounded-2xl bg-red-50 border border-red-100 p-4">
      <ul class="text-sm text-red-700 space-y-1">
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: registration_path, scope: :user, method: :post, class: "space-y-4" do |form| %>
    <%= form.email_field :email, required: true, autofocus: true, autocomplete: "username",
          placeholder: "Email", class: input_classes %>

    <%= form.password_field :password, required: true, autocomplete: "new-password",
          placeholder: "Password (min 8 chars)", maxlength: 72, class: input_classes %>

    <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
          placeholder: "Confirm password", maxlength: 72, class: input_classes %>

    <div class="pt-2">
      <%= form.submit "Sign up", class: button_classes(:primary, extra: "w-full") %>
    </div>

    <div class="pt-4 text-center text-sm text-neutral-500">
      Already have an account? <%= link_to "Sign in", new_session_path, class: "text-neutral-900 font-medium underline hover:no-underline" %>
    </div>
  <% end %>
</div>
