<% flash.each do |type, message| %>
  <div class="fixed inset-x-0 top-4 z-50 flex justify-center px-4 pointer-events-none"
       data-controller="flash"
       data-flash-delay-value="3500">
    <div class="pointer-events-auto rounded-full px-5 py-3 text-sm font-medium shadow-lg <%= type.to_s == "alert" ? "bg-red-600 text-white" : "bg-neutral-900 text-white" %>">
      <%= message %>
    </div>
  </div>
<% end %>
