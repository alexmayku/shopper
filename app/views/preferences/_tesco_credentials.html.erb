<section class="<%= card_classes %>">
  <h2 class="text-lg font-semibold">Tesco sign-in</h2>
  <p class="mt-2 text-sm text-neutral-600 leading-relaxed">
    We use these to log in on your behalf when you tap Add to Basket. Your password is encrypted and only decrypted inside the worker that builds your basket. We never see it. We never log it.
  </p>

  <div class="mt-4 space-y-3">
    <% if user.tesco_email.present? %>
      <p class="text-sm text-neutral-500">
        Currently set for <span class="font-medium text-neutral-900"><%= user.tesco_email %></span>.
      </p>
    <% else %>
      <p class="text-sm text-neutral-500">Not set.</p>
    <% end %>

    <%= form.email_field :tesco_email, autocomplete: "off", placeholder: "Tesco email", class: input_classes %>
    <%= form.password_field :tesco_password, autocomplete: "new-password", placeholder: "Tesco password", class: input_classes %>
  </div>

  <% if user.tesco_email.present? || user.tesco_password.present? %>
    <div class="mt-4">
      <%= button_to "Clear Tesco credentials", clear_tesco_credentials_path, method: :delete,
            class: button_classes(:secondary, extra: "w-full"),
            form: { data: { turbo_confirm: "Clear stored Tesco credentials?" } } %>
    </div>
  <% end %>
</section>
