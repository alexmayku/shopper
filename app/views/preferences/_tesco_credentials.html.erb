<section class="<%= card_classes %>">
  <h2 class="text-lg font-semibold">Tesco sign-in</h2>

  <% if user.tesco_session_state.present? %>
    <div class="mt-3 flex items-center gap-2">
      <span class="w-2.5 h-2.5 rounded-full bg-emerald-500"></span>
      <span class="text-sm font-medium text-neutral-900">Connected to Tesco</span>
    </div>
    <% if user.tesco_session_saved_at %>
      <p class="mt-1 text-sm text-neutral-500">
        Last signed in <%= time_ago_in_words(user.tesco_session_saved_at) %> ago
      </p>
    <% end %>
  <% else %>
    <p class="mt-2 text-sm text-neutral-600 leading-relaxed">
      Connect your Tesco account to let us build your basket automatically.
      You'll sign in directly with Tesco — we never see your password.
    </p>
  <% end %>
</section>
