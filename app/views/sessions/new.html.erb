<div class="pt-4">
  <h1 class="text-3xl font-semibold tracking-tight mb-8">Sign in</h1>

  <%= form_with url: session_url, class: "space-y-4" do |form| %>
    <%= form.email_field :email, required: true, autofocus: true, autocomplete: "username",
          placeholder: "Email", value: params[:email], class: input_classes %>

    <%= form.password_field :password, required: true, autocomplete: "current-password",
          placeholder: "Password", maxlength: 72, class: input_classes %>

    <div class="pt-2">
      <%= form.submit "Sign in", class: button_classes(:primary, extra: "w-full") %>
    </div>

    <div class="pt-4 text-center text-sm text-neutral-500">
      New to Kart? <%= link_to "Create an account", new_registration_path, class: "text-neutral-900 font-medium underline hover:no-underline" %>
    </div>
  <% end %>
</div>
