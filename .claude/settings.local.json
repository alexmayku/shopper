{
  "permissions": {
    "allow": [
      "Bash(ruby -v)",
      "Bash(rails -v)",
      "Bash(psql --version)",
      "Bash(rails new:*)",
      "Bash(bundle install:*)",
      "Bash(bin/rails db:prepare)",
      "Bash(bin/rails test:*)",
      "Bash(bin/rails runner:*)",
      "Bash(git add:*)",
      "Bash(git commit -m ':*)",
      "Bash(bin/rails g:*)",
      "Bash(bin/rails db:migrate)",
      "Bash(bin/rails db:rollback STEP=7)",
      "Bash(bin/rails db:test:prepare)",
      "Bash(bin/rails db:system:change --to=postgresql)",
      "Bash(bin/rails db:encryption:init)",
      "Bash(EDITOR=\"tee\" bin/rails credentials:show)"
    ]
  }
}
