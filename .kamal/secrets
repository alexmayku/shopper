# Secrets sourced into Kamal at deploy time. Never check raw values in.
# Read everything from the local environment — set them via direnv, 1Password,
# or whatever the operator prefers before running `kamal deploy`.

KAMAL_REGISTRY_USERNAME=$KAMAL_REGISTRY_USERNAME
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

RAILS_MASTER_KEY=$(cat config/master.key)

DATABASE_URL=$DATABASE_URL
SECRET_KEY_BASE=$SECRET_KEY_BASE

ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY

STRIPE_SECRET_KEY=$STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=$STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_ID_MONTHLY=$STRIPE_PRICE_ID_MONTHLY
STRIPE_PRICE_ID_ANNUAL=$STRIPE_PRICE_ID_ANNUAL

RESEND_API_KEY=$RESEND_API_KEY

SIDECAR_HMAC_SECRET=$SIDECAR_HMAC_SECRET

POSTGRES_PASSWORD=$POSTGRES_PASSWORD
