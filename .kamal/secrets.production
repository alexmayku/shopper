# Production secrets — sourced from the operator's environment at deploy time.
# Set these via direnv / 1Password / your secret manager BEFORE running:
#
#   kamal -d production deploy
#
# Never commit raw values.

KAMAL_REGISTRY_USERNAME=$KAMAL_REGISTRY_USERNAME
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

RAILS_MASTER_KEY=$(cat config/master.key)

DATABASE_URL=$KART_PROD_DATABASE_URL
SECRET_KEY_BASE=$KART_PROD_SECRET_KEY_BASE

ANTHROPIC_API_KEY=$KART_PROD_ANTHROPIC_API_KEY

# Stripe LIVE keys (created in the Stripe dashboard, not the test mode toggle).
STRIPE_SECRET_KEY=$KART_PROD_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=$KART_PROD_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_ID_MONTHLY=$KART_PROD_STRIPE_PRICE_ID_MONTHLY
STRIPE_PRICE_ID_ANNUAL=$KART_PROD_STRIPE_PRICE_ID_ANNUAL

# Resend production key bound to the verified sending domain.
RESEND_API_KEY=$KART_PROD_RESEND_API_KEY

SIDECAR_HMAC_SECRET=$KART_PROD_SIDECAR_HMAC_SECRET

POSTGRES_PASSWORD=$KART_PROD_POSTGRES_PASSWORD

# Residential proxy credentials (IPRoyal / Bright Data / etc).
PROXY_PROVIDER_USER=$KART_PROD_PROXY_PROVIDER_USER
PROXY_PROVIDER_PASS=$KART_PROD_PROXY_PROVIDER_PASS
PROXY_PROVIDER_HOST=$KART_PROD_PROXY_PROVIDER_HOST
